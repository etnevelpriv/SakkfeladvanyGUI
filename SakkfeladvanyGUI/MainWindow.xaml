<Window x:Class="SakkfeladvanyGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SakkfeladvanyGUI"
        mc:Ignorable="d"
        Title="Sakkfeladvány" Height="450" Width="800">
    <Grid Margin="10">
        <TextBlock Text="Sakktábla mérete [sor x oszlop]: " HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" />
        <ComboBox x:Name="rowCB" Width="50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="180,10,0,0"/>
        <ComboBox x:Name="colCB" Width="50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="250,10,0,0"/>

        <Button x:Name="createButton" Content="Tábla létrehozása" Width="150" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,50,0,0" Click="createButton_Click" />

        <TextBlock x:Name="uzenetTB" Text="Minden sorban helyezzen el egy királynőt!" Margin="10,90,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
    </Grid>
</Window>
